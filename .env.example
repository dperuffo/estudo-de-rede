# EMAIL_FROM=noreply@fni.com.br

# ── App ──────────────────────────────────────────────────────────
# E-mail do administrador global (sem alterar o código)
ADMIN_EMAIL=d.peruffo@gmail.com
# Ambiente: development | production
APP_ENV=production
