# ═══════════════════════════════════════════════════════════════════
#  FNI Pró-Frotas — Variáveis de Ambiente
#  Fase 1: Configuração para Railway / Render / qualquer PaaS
#
#  ⚠️  NUNCA commite o arquivo .env real no Git.
#      Copie este arquivo para .env e preencha os valores reais.
#      Adicione .env ao .gitignore.
# ═══════════════════════════════════════════════════════════════════

# ── Supabase ─────────────────────────────────────────────────────
SUPABASE_URL=https://seu-projeto.supabase.co
# Use a service_role key para o backend (não a anon key)
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Google OAuth (Streamlit OAuth) ───────────────────────────────
GOOGLE_CLIENT_ID=000000000000-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# URL de redirect — deve coincidir com a configurada no Google Cloud Console
OAUTH_REDIRECT_URI=https://seu-app.railway.app

# ── Stripe (Fase 2 — preencher na Fase 2) ────────────────────────
# STRIPE_SECRET_KEY=sk_live_SUA_CHAVE_AQUI
# STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# STRIPE_PRICE_BASICO=price_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# STRIPE_PRICE_PROFISSIONAL=price_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Redis Cache (Fase 5 — preencher na Fase 5) ───────────────────
