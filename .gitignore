# ═══════════════════════════════════════════════════════════════════
#  FNI Pró-Frotas — .gitignore
#  NUNCA commite arquivos desta lista — contêm credenciais sensíveis
# ═══════════════════════════════════════════════════════════════════

# ── SECRETS — NUNCA no Git ───────────────────────────────────────
.env
.env.local
.env.production
.env.*
!.env.example

# Streamlit secrets (contêm SUPABASE_KEY, GOOGLE_CLIENT_SECRET, etc.)
.streamlit/secrets.toml
**/secrets.toml

# ── Python ────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ── Ambientes virtuais ────────────────────────────────────────────
venv/
.venv/
env/
.env_folder/

# ── Sistema operacional ───────────────────────────────────────────
.DS_Store
.DS_Store?
Thumbs.db
desktop.ini
*~

# ── IDEs ──────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo

# ── Planilhas e PDFs locais (não são código) ─────────────────────
# Descomente se não quiser versionar estes arquivos:
# *.xlsx
# *.xls
# *.pdf

# ── Logs ─────────────────────────────────────────────────────────
*.log
logs/

# wrangler files
.wrangler
.dev.vars*
!.dev.vars.example
